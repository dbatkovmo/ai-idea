{
  "name": "ai-football-value-platform",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:api": "uvicorn app.main:app --reload --app-dir apps/api",
    "dev:web": "pnpm --dir apps/web dev",
    "db:migrate": "cd apps/api && alembic upgrade head",
    "db:seed": "cd apps/api && python -m app.db.seed",
    "lint:web": "pnpm --dir apps/web lint",
    "typecheck:web": "pnpm --dir apps/web typecheck"
  },
  "workspaces": [
    "apps/*"
  ]
}
